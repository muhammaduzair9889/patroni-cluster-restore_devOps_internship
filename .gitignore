# .gitignore - Files to Exclude from Git

# Sensitive Files
/etc/pgbackrest/pgbackrest.conf
/etc/patroni/patroni.yml
*.key
*.pem
*.crt
.ssh/

# Logs & Temporary Files
*.log
*.log.*
/var/log/
*.tmp
/tmp/

# Backup & Repository Files
/mnt/pgbackrest-repo/
*.backup
*.bak
*.old

# Database Files
/var/lib/postgresql/
pg_wal/
pg_xlog/
base/
global/

# System Files
.DS_Store
*.swp
*.swo
*~
.vscode/
.idea/

# Generated Files
/test-results/
/build/
*.pyc
__pycache__/
.pytest_cache/
*.egg-info/

# IDE Files
.vscode/*
!.vscode/settings.json
.idea/*
*.sublime-project
*.sublime-workspace

# OS Files
Thumbs.db
.directory
.AppleDouble
.LSOverride

# Documentation Generated
/docs/_build/
site/

# Credentials (Never commit!)
.env
.env.local
secrets.yml
credentials.json
passwords.txt
